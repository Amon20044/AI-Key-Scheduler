{
  "name": "@ai-key-scheduler/langchain",
  "version": "0.3.1",
  "description": "LangChain adapter for @ai-key-scheduler/core.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amon20044/AI-Key-Scheduler.git",
    "directory": "packages/langchain"
  },
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.types.json && node ../../scripts/fix-cjs-extensions.cjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "langchain",
    "api-keys",
    "scheduler",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-key-scheduler/core": "0.3.1"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0",
    "langchain": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "langchain": {
      "optional": true
    }
  }
}
