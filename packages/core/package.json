{
  "name": "@ai-key-scheduler/core",
  "version": "0.3.2",
  "description": "Core scheduler, heap, LRU, cooldown, state, retry, and error handling for AI API keys.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amon20044/AI-Key-Scheduler.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.types.json && node ../../scripts/fix-cjs-extensions.cjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:security": "vitest run tests/security.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai-key-scheduler",
    "rate-limit",
    "api-keys",
    "scheduler",
    "ai",
    "llm"
  ],
  "author": "",
  "license": "MIT"
}
