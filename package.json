{
  "name": "ai-key-manager",
  "version": "0.3.3",
  "description": "TypeScript adaptive AI key scheduling with provider-level routing, key-level strategies, rate-limit retry, cooldown, and provider/model failover.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amon20044/AI-Key-Scheduler.git"
  },
  "bugs": {
    "url": "https://github.com/Amon20044/AI-Key-Scheduler/issues"
  },
  "homepage": "https://github.com/Amon20044/AI-Key-Scheduler#readme",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.types.json && node scripts/fix-cjs-extensions.cjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run test:security && npm run build",
    "test": "vitest run",
    "test:security": "vitest run tests/security.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai-key-manager",
    "ai-key-scheduler",
    "ai key manager",
    "ai key scheduler",
    "api-key-manager",
    "api-key-rotation",
    "api-key-scheduler",
    "api key manager",
    "api key rotation",
    "api key scheduler",
    "api-keys",
    "api keys",
    "key-rotation",
    "key-scheduler",
    "key-selection-strategy",
    "adaptive-key-selection",
    "weighted-key-selection",
    "random-key-selection",
    "key rotation",
    "key scheduler",
    "rate-limit",
    "rate-limit-retry",
    "rate-limit-handler",
    "rate limit",
    "rate limit retry",
    "rate limit handler",
    "quota-management",
    "quota management",
    "retry",
    "retries",
    "fallback",
    "failover",
    "cooldown",
    "provider-fallback",
    "provider-strategy",
    "adaptive-routing",
    "adaptive scheduler",
    "provider selection",
    "max heap",
    "model-fallback",
    "provider fallback",
    "model fallback",
    "scheduler",
    "ai",
    "llm",
    "llmops",
    "openai",
    "openrouter",
    "gemini",
    "anthropic",
    "node",
    "nodejs",
    "typescript"
  ],
  "sideEffects": false,
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
